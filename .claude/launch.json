      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),path=require('path');const root='C:/Users/nicol/Downloads/claire-project';const mime={'html':'text/html','css':'text/css','js':'application/javascript','json':'application/json','png':'image/png','jpg':'image/jpeg','jpeg':'image/jpeg','svg':'image/svg+xml','ico':'image/x-icon'};h.createServer((req,res)=>{let f=path.join(root,req.url.split('?')[0]==='/'?'/index.html':req.url.split('?')[0]);if(!fs.existsSync(f)||fs.statSync(f).isDirectory()){res.writeHead(404);return res.end('Not found');}const ext=f.split('.').pop();res.writeHead(200,{'Content-Type':mime[ext]||'text/plain'});res.end(fs.readFileSync(f));}).listen(8080,()=>console.log('Serving on 8080'))"],
